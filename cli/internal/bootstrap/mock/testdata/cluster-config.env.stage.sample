# Cluster: stage
# Stage cluster — stage.kube-dc.com

CLUSTER_NAME=stage
DOMAIN=stage.kube-dc.com
NODE_EXTERNAL_IP=88.99.29.250
EMAIL=noreply@kube-dc.com
KUBE_API_EXTERNAL_URL=https://kube-api.stage.kube-dc.com:6443
KEYCLOAK_HOSTNAME=login.stage.kube-dc.com

# Network — ext-cloud (cloud NAT pool)
EXT_NET_NAME=ext-cloud
EXT_NET_TYPE=cloud
EXT_NET_VLAN_ID=4013
EXT_NET_INTERFACE=enp0s31f6
EXT_NET_CIDR=100.65.0.0/16
EXT_NET_GATEWAY=100.65.0.1
EXT_NET_MTU=1400
EXT_NET_EXCLUDE_IPS=100.65.0.1..100.65.0.100

# Network — ext-public (internet-routable EIPs)
EXT_PUBLIC_VLAN_ID=4011
EXT_PUBLIC_CIDR=168.119.17.48/28
EXT_PUBLIC_GATEWAY=168.119.17.49
EXT_PUBLIC_EXCLUDE_IPS_1=168.119.17.49..168.119.17.50
EXT_PUBLIC_EXCLUDE_IPS_2=168.119.17.60

# Kube-OVN external gateway nodes (all nodes with br-ext-cloud)
KUBE_OVN_GW_NODES=kube-dc-master-1,kube-dc-worker-1
# distributed: each node ARPs only for its own local pods' external IPs.
# Prevents both nodes from simultaneously ARPing for ALL external IPs (high ARP
# traffic reported by Hetzner on ge-0/0/18.0 VLANs 4011/4013, 2026-04-29).
KUBE_OVN_GW_TYPE=centralized

POD_CIDR=10.100.0.0/16
POD_GATEWAY=10.100.0.1
SVC_CIDR=10.101.0.0/16
K8S_SERVICE_IP=10.101.0.1
CLUSTER_DNS=10.101.0.11
JOIN_CIDR=172.30.0.0/22

# Kube-OVN master nodes
KUBE_OVN_MASTER_NODES=192.168.1.3

# Default network types
DEFAULT_GW_NETWORK_TYPE=cloud
DEFAULT_EIP_NETWORK_TYPE=public
DEFAULT_FIP_NETWORK_TYPE=public
DEFAULT_SVC_LB_NETWORK_TYPE=public

# Monitoring
PROM_STORAGE=20Gi
PROM_RETENTION=365d
PROM_RETENTION_SIZE=17GiB

# SMTP
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# OVN DB IPs (master node IPs for OVN NB/SB)
OVN_DB_IPS=tcp:192.168.1.3:6641

# Object storage (Rook Ceph) — see infrastructure/object-storage/ +
# docs/prd/object-storage-bootstrap.md. Stage uses the loop-device
# variant of rook-ceph-local: a 100 GiB sparse file on the worker
# node's root FS, attached to /dev/loop0, formatted by Rook as the
# single OSD. No real disk needed (cloud follows the same pattern
# but with a 500 GiB sparse file).
ROOK_CEPH_VERSION=v1.19.1
OBJECT_STORAGE_MODE=rook-ceph-local
CEPH_IMAGE=quay.io/ceph/ceph:v19.2.1
CEPH_LOCAL_OSD_NODE=kube-dc-worker-1
CEPH_LOCAL_OSD_DEVICE=loop0
CEPH_LOCAL_OSD_SIZE_GB=100
CEPH_LOCAL_OSD_BACKING_FILE=/var/lib/ceph-osd-block.img
# Public hostname of the per-cluster Rook Ceph RGW. Substituted into
# httproute / certificate / grafana-pg endpointURL via Flux postBuild.
# Without this set, anything that reads ${S3_HOSTNAME} would fall back
# to the literal default `s3.${DOMAIN}` (one substitution pass) which
# may or may not resolve depending on context.
S3_HOSTNAME=s3.stage.kube-dc.com

# Component versions (stage = latest)
# Bumped to v0.3.23 (M1 OpenBao reconcilers: ManagedSecret controller,
# Org+Project OpenBao Namespace/mount/ESO wiring, OrganizationGroup
# policy generator, Organization.status.security rollup). Requires
# hack/openbao-setup-controller-auth.sh to be run once per cluster
# (closes M1 bootstrap gap; see openbao-integration-development-scope §8a).
# Cloud stays on v0.3.22 until stage validation completes.
KUBE_DC_VERSION=v0.3.36
KUBE_DC_MANAGER_TAG=v0.3.36-dev1   # egress firewall fix: drop `ct.new` from lr_in_policy match — see PRD §6.0.8
KUBE_DC_BACKEND_TAG=v0.3.36
KUBE_DC_FRONTEND_TAG=v0.3.36
# OpenBao master-config wiring (v0.3.24 chart). Enabled on stage as
# part of M1 smoke testing — kicks in once
# hack/openbao-setup-controller-auth.sh has been run.
OPENBAO_ENABLED=true
KUBE_DC_K8_MANAGER_TAG=v0.1.35-dev83
DB_MANAGER_TAG=v0.1.3-dev2   # M4 / Option H + hardening pass: copy RW selector (MariaDB HA fix) + ownership-collision + OpenBao-disabled GC (PRD §6.0.7 + review 2026-05-23)
CERT_MANAGER_VERSION=v1.20.1
KUBE_OVN_VERSION=v1.15.10
ENVOY_GATEWAY_VERSION=v1.7.1
KEYCLOAK_VERSION=24.3.0
PROM_OPERATOR_VERSION=83.4.0
LOKI_VERSION=13.4.1
# chart 1.8.0 = Alloy v1.16.0
ALLOY_VERSION=1.8.0
KUBEVIRT_VERSION=v1.8.1
KUBEVIRT_CDI_VERSION=v1.65.0
KYVERNO_VERSION=v1.17.1
SVELTOS_VERSION=v0.57.2
KAMAJI_IMAGE_TAG=edge-26.02.11-v4-kube-dc
CNPG_VERSION=0.28.0
MARIADB_OPERATOR_VERSION=26.3.0
MULTUS_VERSION=v4.2.4
LOCAL_PATH_VERSION=v0.0.35

# OpenBao + External Secrets Operator — dev-scope §11 (kube-dc/docs/prd/
# openbao-integration-development-scope.md). Phase-1 stage values; HA
# and storage size are intentionally small until M0-T08 acceptance.
OPENBAO_VERSION=2.5.3
OPENBAO_CHART_VERSION=0.28.2
OPENBAO_REPLICAS=1
# HA=true with replicas=1 gives single-node Raft storage on stage,
# matching the data format we'll use on production at 3 replicas
# (so future scale-up is a values bump, not a storage migration).
OPENBAO_HA_ENABLED=true
OPENBAO_STORAGE_SIZE=20Gi
OPENBAO_STORAGE_CLASS=local-path
ESO_VERSION=2.5.0
