# Cluster: cloud (kube-dc.cloud)
# Production cluster — deployed via cluster.dev from /home/voa/projects/kube-dc.cloud
# Migrating to GitOps (kube-dc-fleet) without disruption to live user workloads.
#
# All values MUST match what is running on the cluster to avoid any Helm upgrade
# drift during adoption. Bump versions via PR only after initial adoption is stable.

CLUSTER_NAME=cloud
DOMAIN=kube-dc.cloud
NODE_EXTERNAL_IP=213.111.154.233
EMAIL=noreply@kube-dc.com
KUBE_API_EXTERNAL_URL=https://kube-api.kube-dc.cloud:6443
KEYCLOAK_HOSTNAME=login.kube-dc.cloud

# Network — ext-cloud (cloud NAT pool, VLAN 884)
EXT_NET_NAME=ext-cloud
EXT_NET_TYPE=cloud
EXT_NET_VLAN_ID=884
EXT_NET_INTERFACE=enp94s0f0np0
EXT_NET_CIDR=100.65.0.0/16
EXT_NET_GATEWAY=100.65.0.1
EXT_NET_MTU=1400
EXT_NET_EXCLUDE_IPS=100.65.0.1..100.65.0.100

# Network — ext-public (internet-routable EIPs, VLAN 883)
EXT_PUBLIC_VLAN_ID=883
EXT_PUBLIC_CIDR=91.224.11.0/24
EXT_PUBLIC_GATEWAY=91.224.11.1
EXT_PUBLIC_EXCLUDE_IPS_1=91.224.11.1..91.224.11.3
EXT_PUBLIC_EXCLUDE_IPS_2=91.224.11.254

# Kube-OVN external gateway nodes (all nodes wired to ext-cloud bridge)
KUBE_OVN_GW_NODES=ams1-blade179-8,ams1-blade184-5,ams1-blade58-2,ams1-blade187-2

# Default network types — cloud stack is all-"cloud" for GW/EIP/FIP/SVC_LB
# (public is still allocable on demand via externalNetworkType: public)
DEFAULT_GW_NETWORK_TYPE=cloud
DEFAULT_EIP_NETWORK_TYPE=cloud
DEFAULT_FIP_NETWORK_TYPE=cloud
DEFAULT_SVC_LB_NETWORK_TYPE=cloud

# Cluster-internal CIDRs (RKE2 + kube-ovn defaults)
POD_CIDR=10.100.0.0/16
POD_GATEWAY=10.100.0.1
SVC_CIDR=10.101.0.0/16
K8S_SERVICE_IP=10.101.0.1
CLUSTER_DNS=10.101.0.11
JOIN_CIDR=172.30.0.0/22

# OVN master node IPs (3 control-plane nodes run OVN NB/SB)
KUBE_OVN_MASTER_NODES=192.168.0.2,192.168.0.3,192.168.0.4
OVN_DB_IPS=tcp:192.168.0.2:6641,tcp:192.168.0.3:6641,tcp:192.168.0.4:6641

# Monitoring — production: 365d retention, 50Gi storage
# PROM_STORAGE matches the live PVC size to avoid shrink attempt on
# HelmRelease upgrade (StatefulSet VCT is immutable once bound).
# PROM_RETENTION_SIZE matches live retentionSize kept under PVC capacity.
PROM_STORAGE=50Gi
PROM_RETENTION=365d
PROM_RETENTION_SIZE=47GiB

# Grafana database (CNPG `grafana-pg` Cluster in monitoring/) — backs
# tenant-saved dashboards, folders, Grafana Orgs, users. See
# docs/prd/grafana-multi-tenant.md §7.4.1 in the kube-dc repo.
# 10 GiB is well above what 100 Grafana Orgs of dashboards consume.
GRAFANA_PG_STORAGE=10Gi

# SMTP (Gmail, IP-whitelisted)
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Component versions — PINNED to what is currently running on the cluster.
# DO NOT bump on first adoption; upgrade via separate PR after Flux adoption
# succeeds and components report Ready.
KUBE_DC_VERSION=v0.3.62
                                      # v0.3.10 — Phase 0+1 of CDI acceleration PRD:
                                      # drops the dead Gentoo entry, extends
                                      # cdi-upload-gc with Failed-DV cleanup (6h),
                                      # refactors os-images-configmap into a values-
                                      # driven catalog with mirrorBaseURL hook, and
                                      # swaps the gc CronJob image off bitnami/kubectl
                                      # (404'd) to shalb/kubectl-jq:v1.35.4.
                                      # v0.3.8 — KdcDatabase restore: bootstrap.recovery
                                      # (CNPG) / bootstrapFrom (MariaDB) wired through
                                      # spec.restoreFrom + kube-dc.com/restore-from
                                      # annotation. Chart RBAC adds cnpg.io/backups,
                                      # k8s.mariadb.com/backups, persistentvolumeclaims
                                      # delete (db-manager), plus tenant reads on
                                      # cnpg.io/clusters and k8s.mariadb.com/mariadbs
                                      # for UI restore-progress display.
                                      # v0.2.12 — Managed-K8s etcd backup pipeline:
                                      # KdcCluster.spec.backup CRD field,
                                      # per-Project managed-k8s-backups OBC,
                                      # k8-manager BackupReady condition,
                                      # batch/cronjobs RBAC,
                                      # objectbucketclaims read RBAC,
                                      # S3_ENDPOINT env injected on k8-manager
                                      # so backup CronJobs running in isolated
                                      # project VPCs reach the public S3
                                      # hostname instead of the cluster-local
                                      # rook-ceph-rgw service (cross-VPC).
                                      # See kube-dc-k8-manager/docs/prd/managed-k8s-etcd-backups.md
# Bumped to v0.3.22 (M0 OpenBao integration: security CRDs + admission
# webhooks + ProjectStatusAggregator + ConfigGlobal extension; chart
# template manager-webhook.yaml adds the Service + cert-manager
# Certificate + Mutating/ValidatingWebhookConfiguration).
# Validated end-to-end on stage at this version before this bump.
# k8-manager and db-manager are untouched by M0 — kept at their
# existing dev pins.
KUBE_DC_MANAGER_TAG=v0.3.62-dev2   # DBCP webhook reservedUsernames (kdc_rotator/postgres on PG, root on MariaDB) + openbao package rotate-root forbidden comment fence + rotation-aware requeue (from v0.3.62-dev1)
KUBE_DC_BACKEND_TAG=v0.3.62-dev1   # rotate-root route retired: POST /rotate?root=true returns 410 Gone with PRD-pointing hint; openbao helper rotateDatabaseRoot deleted; regression test pins behavior
KUBE_DC_FRONTEND_TAG=v0.3.62-dev1   # CreateDatabaseModal break-glass toggle (spec.breakGlass.enableSuperuserAccess) + warning Alert; "Rotate engine root (admin)" row action removed from DBCP list; Review step shows break-glass state
KUBE_DC_K8_MANAGER_TAG=v0.1.35-dev87
DB_MANAGER_TAG=v0.1.4-dev1   # B-superuser fix for openbao-postgres-self-rotation-deadlock PRD: managed.roles[kdc_rotator] with superuser:true (PG16+ ADMIN OPTION restriction), BuildOpenBaoDatabaseConfig reads <db>-rotator strictly, breakGlass.enableSuperuserAccess toggles CNPG enableSuperuserAccess
# OpenBao master-config wiring (v0.3.24+ chart). Enabled on cloud after
# stage validation. Requires hack/openbao-setup-controller-auth.sh to be
# run once per cluster — see commit log + dev-scope §8a.
OPENBAO_ENABLED=true

# Stateless infra — upgraded to stage versions on first Flux reconcile.
# Expect one pod restart per component; no data/state impact.
KUBE_OVN_VERSION=v1.15.10
CERT_MANAGER_VERSION=v1.20.1
ENVOY_GATEWAY_VERSION=v1.7.1
KYVERNO_VERSION=v1.17.1
MULTUS_VERSION=v4.2.4
LOCAL_PATH_VERSION=v0.0.35
SVELTOS_VERSION=v0.57.2

# OpenBao + External Secrets Operator (M0-T08 of the OpenBao integration).
# Cloud production sizing: HA Raft with 3 replicas, 50Gi PVC each. Stage
# uses single-pod (HA=true with replicas=1) for the same Raft storage
# format. ESO is a single deployment cluster-wide.
OPENBAO_VERSION=2.5.3
OPENBAO_CHART_VERSION=0.28.2
OPENBAO_REPLICAS=3
OPENBAO_HA_ENABLED=true
OPENBAO_STORAGE_SIZE=50Gi
OPENBAO_STORAGE_CLASS=local-path
ESO_VERSION=2.5.0

# Stateful components.
# KubeVirt + CDI were already bumped to v1.8.1 / v1.65.0 by the vendored
# manifests during initial Flux adoption (platform/kubevirt/operator.yaml).
# These env vars are documentation only — the actual versions come from the
# vendored manifests. See upgrade-plan.md Phase 1 for VM virt-launcher refresh.
KUBEVIRT_VERSION=v1.8.1
KUBEVIRT_CDI_VERSION=v1.65.0
KEYCLOAK_VERSION=24.3.0
# prom-operator adoption DEFERRED on cloud — requires alertmanager-config-custom
# migration + Grafana OIDC client + nameOverride handling. See
# values-drift.md §6 and upgrade-plan.md Phase 3.
PROM_OPERATOR_VERSION=83.4.0
LOKI_VERSION=13.4.1
ALLOY_VERSION=1.8.0
                                   # NOTE: the original justification (native
                                   # __tenant_id__ translation) was empirically
                                   # disproved against v1.16 — see PRD §14
                                   # risk #8 and grafana/alloy#521. Bump kept
                                   # because (a) it's the latest stable and
                                   # (b) the log path benefits from bug fixes.
                                   # Per-sample tenant routing is now done by
                                   # cortex-tenant (see CORTEX_TENANT_VERSION).
                                   # stage still on 0.10.1.
CORTEX_TENANT_VERSION=0.8.1
                                   # Sits between alloy-metrics and the Mimir
                                   # distributor and translates a per-sample
                                   # `__tenant_id__` label into X-Scope-OrgID.
                                   # See platform/monitoring/cortex-tenant/.
KAMAJI_IMAGE_TAG=edge-26.5.2-v7-kube-dc
# CNPG: live has MESSY state — raw v1.25.4 deploy + HR-managed v1.26.1 deploy
# both present. See upgrade-plan.md Phase 2: clean up raw deployment first,
# then bump chart to 0.28.0 (app 1.29) to match stage.
CNPG_VERSION=0.28.0
MARIADB_OPERATOR_VERSION=26.3.0

# Cloud-only addons (present on this cluster, not on stage)
ROOK_CEPH_VERSION=v1.19.1
# Object storage (see infrastructure/object-storage/ + PRD object-storage-bootstrap)
OBJECT_STORAGE_MODE=rook-ceph-local
CEPH_IMAGE=quay.io/ceph/ceph:v19.2.1
# single-node OSD placement (see snapshot)
CEPH_LOCAL_OSD_NODE=ams1-blade187-2
# host /dev/loop0 backed by /var/lib/ceph-osd-block.img (500GB sparse)
CEPH_LOCAL_OSD_DEVICE=loop0
S3_HOSTNAME=s3.kube-dc.cloud
S3_TLS_ISSUER=letsencrypt-prod-http
# System bucket quotas (M3). Defaults applied if these are unset.
SYSTEM_QUOTA_MIMIR_BLOCKS=200G
SYSTEM_QUOTA_MIMIR_RULER=10G
SYSTEM_QUOTA_MIMIR_ALERTMANAGER=5G
SYSTEM_QUOTA_LOKI_CHUNKS=300G
SYSTEM_QUOTA_LOKI_RULER=10G
# Mimir long-term metrics storage (M5).
MIMIR_VERSION=5.7.0
METALLB_VERSION=v0.15.3
KAMAJI_VERSION=1.0.4-kube-dc
