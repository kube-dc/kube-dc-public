# Sanitized full cluster-config.env fixture for the prefill deny-list test.
# RFC 5737 / 6598 addresses + example.com only (no real infra — cli/ is
# scanned by the no-real-infra lint). Represents a rich cluster: public VLAN,
# gateway nodes, MetalLB + anchors, platform-endpoints, OpenBao/Prom sizing,
# system quotas, SMTP, billing — plus the scaffold-owned versions/derived
# keys the importer must DROP.

# --- identity (promoted → dedicated InitOptions fields) ---
CLUSTER_NAME=dc1
DOMAIN=kdc.example.com
NODE_EXTERNAL_IP=203.0.113.10
EMAIL=ops@example.com

# --- derived / domain-specific (DROP) ---
KUBE_API_EXTERNAL_URL=https://kube-api.kdc.example.com:6443
KEYCLOAK_HOSTNAME=login.kdc.example.com
OVN_DB_IPS=tcp:10.0.0.5:6641

# --- preset network defaults (DROP) ---
EXT_NET_NAME=ext-cloud
EXT_NET_TYPE=cloud
EXT_NET_CIDR=100.65.0.0/16
EXT_NET_GATEWAY=100.65.0.1
EXT_NET_EXCLUDE_IPS=100.65.0.1..100.65.0.100
POD_CIDR=10.100.0.0/16
SVC_CIDR=10.101.0.0/16
CLUSTER_DNS=10.101.0.11
JOIN_CIDR=172.30.0.0/22
DEFAULT_GW_NETWORK_TYPE=cloud
DEFAULT_EIP_NETWORK_TYPE=public

# --- operator network (PRESERVE) ---
EXT_NET_VLAN_ID=100
EXT_NET_INTERFACE=bond0
EXT_NET_MTU=1400
KUBE_OVN_MASTER_NODES=10.0.0.5
KUBE_OVN_GW_NODES=m1,w1,w2
KUBE_OVN_GW_TYPE=centralized
EXT_PUBLIC_VLAN_ID=200
EXT_PUBLIC_CIDR=198.51.100.0/28
EXT_PUBLIC_GATEWAY=198.51.100.1
EXT_PUBLIC_EXCLUDE_IPS_1=198.51.100.1..198.51.100.2
EXT_PUBLIC_EXCLUDE_IPS_2=198.51.100.5
EXT_NET_ANCHOR_IPS=m1=100.65.0.10/16
EXT_NET_ANCHOR_INTERFACE=br-ext-cloud
EXT_NET_ANCHOR_REQUIRED=false
EXT_NET_ANCHOR_SSH_HOSTS=m1=ubuntu@203.0.113.10
METALLB_INTERFACE=bond0
METALLB_FLOATING_IP=203.0.113.9

# --- object storage (promoted fields + preserved replication) ---
OBJECT_STORAGE_MODE=rook-ceph-local
CEPH_LOCAL_OSD_NODE=dc1-m1
CEPH_LOCAL_OSD_SIZE_GB=500
CEPH_REPLICATION_SIZE=2
S3_HOSTNAME=s3.kdc.example.com

# --- platform-endpoints + features (PRESERVE) ---
KUBE_API_INTERNAL_VIP=10.101.0.50
PLATFORM_ENDPOINT_KUBE_API_ENABLED=true
ENVOY_GATEWAY_INTERNAL_VIP=10.101.0.51
PLATFORM_ENDPOINT_ENVOY_GATEWAY_ENABLED=true
INGRESS_HOST_CIDR=10.101.0.0/24
INGRESS_GLOBAL_ALLOWLIST=10.0.0.0/8
EGRESS_GLOBAL_ALLOWLIST=10.0.0.0/8
OPENBAO_ENABLED=true
OPENBAO_REPLICAS=1
OPENBAO_STORAGE_SIZE=20Gi
PROM_MEM_LIMIT=2Gi
SYSTEM_QUOTA_MIMIR_BLOCKS=50Gi
SYSTEM_QUOTA_LOKI_CHUNKS=50Gi
SMTP_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
BILLING_PROVIDER=whmcs
SSO_ENABLED=true

# --- versions / images (DROP) ---
KUBE_DC_VERSION=v0.4.0
KUBE_DC_MANAGER_TAG=v0.4.0-1
KUBE_OVN_VERSION=v1.15.10
CERT_MANAGER_VERSION=v1.20.1
CEPH_IMAGE=quay.io/ceph/ceph:v19.2.1
KMS_PLUGIN_IMAGE=example/kms:v1
