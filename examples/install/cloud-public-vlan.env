# kube-dc bootstrap init spec — cloud+public-vlan preset (adds a routed public VLAN)
#
#   kube-dc bootstrap init --config cloud-public-vlan.env
#
# See internal-only.env for the format + precedence notes.

# --- identity ---
CLUSTER_NAME=dc1
DOMAIN=kdc.example.com
NODE_EXTERNAL_IP=203.0.113.10
EMAIL=ops@example.com

# --- network: cloud NAT pool + a routed public VLAN for EIPs ---
EXT_NET_VLAN_ID=100
EXT_NET_INTERFACE=bond0
KUBE_OVN_MASTER_NODES=10.0.0.5
EXT_PUBLIC_VLAN_ID=200
EXT_PUBLIC_CIDR=198.51.100.0/28
EXT_PUBLIC_GATEWAY=198.51.100.1

# --- object storage: 3-node raw-device Ceph (production HA) ---
# Each OSD is two keys — the host and its raw device — exactly as the
# scaffold writes them into cluster-config.env (so this file round-trips).
OBJECT_STORAGE_MODE=rook-ceph-multi-node
CEPH_NODE_1=dc1-master-1
CEPH_NODE_1_DEVICE=sdb
CEPH_NODE_2=dc1-worker-1
CEPH_NODE_2_DEVICE=sdb
CEPH_NODE_3=dc1-worker-2
CEPH_NODE_3_DEVICE=sdb

# --- install-only orchestration ---
KUBE_DC_INIT_MODE=install
KUBE_DC_INIT_FLEET_MODE=new-repo
KUBE_DC_INIT_PRESET=cloud+public-vlan
KUBE_DC_INIT_GITHUB_OWNER=my-org
KUBE_DC_INIT_GITHUB_REPO=my-fleet
KUBE_DC_INIT_SSH_HOST=ubuntu@203.0.113.10
