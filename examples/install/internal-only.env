# kube-dc bootstrap init spec — internal-only preset (dev / no external VLAN)
#
# Copy this file, edit the values for your cluster, then either:
#   kube-dc bootstrap init --config internal-only.env          # opens the panel PRE-FILLED
#   kube-dc bootstrap init --config internal-only.env --yes --no-tty   # headless
#
# Config keys use the SAME names as a cluster's cluster-config.env (so an
# existing cluster's file is also a valid --config). KUBE_DC_INIT_* keys are
# install-only orchestration and are stripped before the cluster's real
# config is written. Precedence: defaults < --config < KUBE_DC_INIT_* env < flags < TUI edits.

# --- identity ---
CLUSTER_NAME=dc1
DOMAIN=kdc.example.com
NODE_EXTERNAL_IP=203.0.113.10
EMAIL=ops@example.com

# --- network (internal-only still needs the node's NIC + kube-ovn master IP) ---
EXT_NET_VLAN_ID=0
EXT_NET_INTERFACE=enp1s0
KUBE_OVN_MASTER_NODES=10.0.0.5

# --- object storage ---
OBJECT_STORAGE_MODE=rook-ceph-local
CEPH_LOCAL_OSD_NODE=dc1-master-1
CEPH_LOCAL_OSD_SIZE_GB=40

# --- install-only orchestration ---
KUBE_DC_INIT_MODE=install
KUBE_DC_INIT_FLEET_MODE=new-repo
KUBE_DC_INIT_PRESET=internal-only
KUBE_DC_INIT_GITHUB_OWNER=my-org
KUBE_DC_INIT_GITHUB_REPO=my-fleet
KUBE_DC_INIT_SSH_HOST=ubuntu@203.0.113.10
# Nested / cloud VM without /dev/kvm? uncomment so the NFD gate doesn't block:
# KUBE_DC_INIT_ALLOW_NO_KVM=true
